APP_NAME=Hub de IA - Python AI Service
APP_ENV=local
APP_DEBUG=true
APP_VERSION=1.0.0
API_V1_PREFIX=/api/v1

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5045,https://localhost:7045,http://10.0.2.2:5045

LOG_LEVEL=INFO

TRANSCRIPTION_DEFAULT_MODEL=small
TRANSCRIPTION_DEVICE=auto
TRANSCRIPTION_COMPUTE_TYPE=auto
TRANSCRIPTION_CPU_THREADS=4
TRANSCRIPTION_NUM_WORKERS=1
TRANSCRIPTION_MAX_UPLOAD_MB=1024
TRANSCRIPTION_BEAM_SIZE=5
TRANSCRIPTION_VAD_FILTER=true
TRANSCRIPTION_WORD_TIMESTAMPS=false
TRANSCRIPTION_INTERNAL_API_KEY=change_me_internal_api_key

SHARED_STORAGE_ROOT=shared_storage
SHARED_UPLOADS_FOLDER_NAME=uploads
SHARED_OUTPUTS_FOLDER_NAME=outputs

FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
FFMPEG_VIDEO_CODEC=libx264
FFMPEG_AUDIO_CODEC=aac
FFMPEG_CRF=20
FFMPEG_PRESET=medium
FFMPEG_OVERWRITE=true

SUBTITLE_DEFAULT_STYLE=default
SUBTITLE_FONT_NAME=Arial
SUBTITLE_FONT_SIZE=18
SUBTITLE_MARGIN_V=28
SUBTITLE_OUTLINE=2
SUBTITLE_SHADOW=0
SUBTITLE_ALIGNMENT=2
SUBTITLE_PRIMARY_COLOUR=&H00FFFFFF
SUBTITLE_OUTLINE_COLOUR=&H00000000
SUBTITLE_BACK_COLOUR=&H64000000

UPLOADS_ROOT=shared_storage

OLLAMA_BASE_URL=http://127.0.0.1:11435
OLLAMA_DEFAULT_MODEL=qwen2.5vl:7b
OLLAMA_TEXT_MODEL=qwen2.5:14b
OLLAMA_VISUAL_MODEL=qwen2.5vl:7b

REMOTE_API_ENABLED=false
REMOTE_API_BASE_URL=
REMOTE_API_API_KEY=change_me_remote_api_key
REMOTE_API_MODELS=qwen3-vl:235b-cloud,qwen3-vl:30b-a3b-instruct-q4_K_M,qwen2.5vl:32b
