{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=55432;Database=appdb;Username=app;Password=change_me_postgres_password"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Infrastructure.Transcription": "Information",
      "Infrastructure.Storage": "Information"
    }
  },
  "Jwt": {
    "Issuer": "HubDeIaApi",
    "Audience": "HubDeIaApp",
    "Key": "change_me_local_jwt_key_with_32_chars_minimum",
    "AccessTokenMinutes": 60
  },
  "PythonTranscription": {
    "BaseUrl": "http://127.0.0.1:8001",
    "CallbackBaseUrl": "http://127.0.0.1:5045",
    "InternalApiKey": "change_me_internal_api_key",
    "TimeoutMinutes": 480,
    "JobsRoute": "api/v1/transcription/jobs/run"
  },
  "TranscriptionStorage": {
    "RootPath": "../../../shared_storage",
    "UploadsFolderName": "uploads",
    "OutputsFolderName": "outputs",
    "MaxUploadMb": 1024,
    "AllowedExtensions": [
      ".mp4",
      ".mov",
      ".mkv",
      ".avi",
      ".webm",
      ".mp3",
      ".wav",
      ".m4a",
      ".aac",
      ".flac",
      ".ogg"
    ]
  }
}
